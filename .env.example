# ──────────────────────────────────────────────────────────────────────────────
# Ticketarget — environment template. Copy to `.env` and adjust.
# ──────────────────────────────────────────────────────────────────────────────

COMPOSE_PROJECT_NAME=ticketarget
APP_ENV=local
APP_DEBUG=true
PHP_VERSION=8.5
ROOT_DOMAIN=ticketarget.localhost

# Host ports for the Traefik edge. Change these if something already owns them
# on your machine (e.g. another reverse proxy on 8080 or a local web server on 80).
HTTP_PORT=80
HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=18080

# Host ports for local dev access to infra (container-internal ports are
# unchanged — services still talk to each other on 5432/6379/9200/9092).
# 5-digit defaults avoid clashing with locally-installed Postgres/Redis/etc.
POSTGRES_PRIMARY_PORT=55432
POSTGRES_REPLICA_PORT=55433
REDIS_HOST_PORT=56379
ELASTICSEARCH_HOST_PORT=59200
KAFKA_HOST_PORT=59092

# ── PostgreSQL (primary + streaming replica) ──────────────────────────────────
POSTGRES_DB=ticketarget
POSTGRES_USER=ticketarget
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PRIMARY_HOST=postgres-primary
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_PORT=5432
# Dedicated replication role used by the replica and by Debezium.
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=change-me-replication

# ── Redis (Sentinel HA) ───────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
REDIS_CACHE_DB=0
REDIS_LOCK_DB=1

# ── Kafka (KRaft) ─────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_LOG_TOPIC=logs.app
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── Debezium / Kafka Connect ──────────────────────────────────────────────────
DEBEZIUM_CONNECT_URL=http://debezium-connect:8083
CDC_TOPIC_PREFIX=ticketarget.cdc
CDC_DLQ_TOPIC=ticketarget.cdc.dlq
CDC_MAX_ATTEMPTS=3

# ── Observability ─────────────────────────────────────────────────────────────
APP_LOGS_INDEX=app-logs
KIBANA_PORT=5601

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_EVENTS_INDEX=events

# ── Stripe (Booking Service) ──────────────────────────────────────────────────
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Waiting-room / bot mitigation (Booking Service) ───────────────────────────
QUEUE_TOKEN_SECRET=change-me-queue-secret
QUEUE_TOKEN_TTL=600
QUEUE_ADMISSION_CAP=5000

# ── Application secrets (generate per service via `make keys`) ─────────────────
EVENT_APP_KEY=
BOOKING_APP_KEY=
APP_SECRET=change-me-symfony-secret

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=kafka
LOG_LEVEL=debug

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://api.ticketarget.localhost
VITE_STRIPE_KEY=pk_test_xxx
